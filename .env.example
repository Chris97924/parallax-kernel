# Parallax runtime configuration
# Copy this file to `.env` and edit values for your local setup.
# All three are optional; defaults resolve under the project root.

# Path to the SQLite database file.
PARALLAX_DB_PATH=./db/parallax.db

# Path to the Obsidian vault root (markdown storage).
PARALLAX_VAULT_PATH=./vault

# Path to the canonical schema (DDL) file.
PARALLAX_SCHEMA_PATH=./schema.sql
